# Configure your commit identity
[user]
	email = matej@framer.com
	name = Matej Konrad


# Enforce SSH access for GitHub
[url "ssh://git@github.com/framer/"]
  insteadOf = https://github.com/framer/

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[url "git@github.com:framer"]
	insteadOf = https://github.com/framer

[credential]
	helper = osxkeychain
[alias]
	cane = commit --amend --no-edit
[push]
	autoSetupRemote = true

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  dark = true
  side-by-side = true
  line-numbers = true
  hyperlinks = true
  syntax-theme = ansi
  file-style = bold yellow
  file-decoration-style = yellow ul
  hunk-header-decoration-style = cyan box
  hunk-header-style = file line-number syntax
  line-numbers-left-style = cyan
  line-numbers-right-style = cyan
  line-numbers-minus-style = red
  line-numbers-plus-style = green
  minus-style = syntax "#3a1f1f"
  minus-emph-style = syntax "#5c2828"
  plus-style = syntax "#1f3a1f"
  plus-emph-style = syntax "#285c28"
  zero-style = syntax
  blame-code-style = syntax
  blame-format = "{author:<18} {commit:<8} {timestamp:>16} "

; [merge]
;   conflictStyle = zdiff3
[pager]
	diff = diffnav
