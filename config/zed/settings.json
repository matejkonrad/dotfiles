// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
	"agent_ui_font_size": 13.0,
 "edit_predictions": {
  "provider": "copilot"
 },
 "diff_view_style": "split",
 "terminal": {
		"font_size": 14.0,
	},
	"which_key": {
		"enabled": true,
	},
	"cli_default_open_behavior": "existing_window",
	"agent_buffer_font_size": 13.0,
	"helix_mode": false,
	"vim_mode": true,
	"proxy": "",
	"agent_servers": {
		"cursor": {
			"default_config_options": {
    "mode": "agent"
   },
   "type": "registry",
		},
		"gemini": {
			"type": "registry",
		},
		"codex-acp": {
			"default_config_options": {
    "mode": "full-access"
   },
   "type": "registry",
		},
		"claude-acp": {
			"type": "registry",
		},
	},
	"project_panel": {
		"dock": "left",
	},
	"outline_panel": {
		"dock": "left",
	},
	"collaboration_panel": {
		"dock": "left",
	},
	"git_panel": {
		"tree_view": true,
		"dock": "left",
	},
	"ui_font_weight": 450.0,
	"unnecessary_code_fade": 0.4,
	"ui_font_family": ".ZedSans",
	"buffer_line_height": "comfortable",
	"buffer_font_weight": 400.0,
	"buffer_font_family": ".ZedMono",
	"agent": {
		"profiles": {
   "auto": {
    "name": "Auto",
    "tools": {},
    "enable_all_context_servers": false,
    "context_servers": {}
   }
  },
  "tool_permissions": {
			"default": "allow",
		},
		"single_file_review": true,
		"dock": "right",
		"default_profile": "write",
		"default_model": {
			"effort": "medium",
   "enable_thinking": true,
   "provider": "openai-subscribed",
			"model": "gpt-5.6-terra",
		},
		"model_parameters": [],
	},
	"auto_update_extensions": {
		"biome": false,
	},
	"base_keymap": "VSCode",
	"icon_theme": {
		"mode": "dark",
		"light": "Zed (Default)",
		"dark": "Zed (Default)",
	},
	"ui_font_size": 13.0,
	"buffer_font_size": 12.0,
	"theme": {
		"mode": "dark",
		"light": "Hami Melon Light",
		"dark": "Darkmatter",
	},
	"relative_line_numbers": "enabled",
	"hard_tabs": true,
	"languages": {
		"TypeScript": {
			"hard_tabs": true,
			"tab_size": 4,
			"formatter": {
				"external": {
					"command": "/Users/matejkonrad/.volta/bin/yarn",
					"arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"],
				},
			},
			"format_on_save": "on",
			"language_servers": ["!biome", "..."],
		},
		"TSX": {
			"hard_tabs": true,
			"tab_size": 4,
			"formatter": {
				"external": {
					"command": "/Users/matejkonrad/.volta/bin/yarn",
					"arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"],
				},
			},
			"format_on_save": "on",
			"language_servers": ["!biome", "..."],
		},
	},
	"file_scan_exclusions": ["**/.yarn/*"],
}
