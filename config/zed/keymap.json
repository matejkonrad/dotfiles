// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"context": "Workspace",
		"bindings": {
			"alt-b": "multi_workspace::ToggleWorkspaceSidebar",
			"alt-n": "multi_workspace::NextThread",
			"alt-p": "multi_workspace::PreviousThread",
			// "shift shift": "file_finder::Toggle"
		},
	},
	// Thread sidebar actions
	{
		"context": "ThreadsSidebar && not_searching && !Editor",
		"bindings": {
			"shift-j": "multi_workspace::NextThread",
			"shift-k": "multi_workspace::PreviousThread",
			"ctrl-l": "menu::Confirm",
			"shift-a": "agent::ArchiveSelectedThread",
		},
	},
	// Vim-style pane navigation
 {
    "context": "Editor",
    "bindings": {
      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"]
    }
  },
	// {
	// 	"context": "Dock || Editor || Pane",
	// 	"bindings": {
	// 		"ctrl-h": "workspace::ActivatePaneLeft",
	// 		"ctrl-j": "workspace::ActivatePaneDown",
	// 		"ctrl-k": "workspace::ActivatePaneUp",
	// 		"ctrl-l": "workspace::ActivatePaneRight",
	// 	},
	// },
	{
		"context": "(vim_mode == helix_normal || vim_mode == helix_select || vim_mode == normal || vim_mode == visual) && !menu", "bindings": { "s": "vim::HelixJumpToWord",
		},
	},
	// ctrl-w w closes the active item instead of cycling panes
	{
		"context": "(VimControl && !menu) || (!Editor && !Terminal)",
		"bindings": {
			"ctrl-w w": "pane::CloseActiveItem",
			"ctrl-w ctrl-w": "pane::CloseActiveItem",
		},
	},
	// ctrl-b toggles the left dock instead of vim's page-up in normal mode
	{
		"context": "VimControl && !menu",
		"bindings": {
			"ctrl-b": "workspace::ToggleLeftDock",
		},
	}
]
